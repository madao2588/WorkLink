APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_EXPOSE_INTERNAL_ERRORS=true
APP_NAME=WorkLink Backend
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+psycopg://worklink:worklink123@127.0.0.1:5432/worklink
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:8000
